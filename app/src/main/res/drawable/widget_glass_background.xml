<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow for 3D depth -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#33000000" />
        </shape>
    </item>

    <!-- Main glass layer - frosted translucent white -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#D0FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- Top glass highlight for 3D effect -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="270"
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Bottom subtle shadow for depth -->
    <item
        android:left="6dp"
        android:top="0dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="90"
                android:startColor="#20000000"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>