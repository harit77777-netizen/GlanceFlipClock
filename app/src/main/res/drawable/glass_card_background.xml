<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Drop shadow for 3D depth -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#1A000000" />
        </shape>
    </item>

    <!-- Frosted glass main layer -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#CCFFFFFF" />
            <stroke
                android:width="0.5dp"
                android:color="#60FFFFFF" />
        </shape>
    </item>

    <!-- Glass reflection highlight top -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#50FFFFFF"
                android:centerColor="#10FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Subtle bottom shadow for depth -->
    <item
        android:left="4dp"
        android:top="2dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#15000000"
                android:centerColor="#05000000"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>